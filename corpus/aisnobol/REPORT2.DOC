              +        :S(RETURN)
          115       SETRQ = PATH( .Y, #"(SUBSET +)", .X)   SOMETIMES
              +        :S(RETURN)
          116       SETRQ = INSUFFICIENT   :(RETURN)
          117 SETRQ.END
              *
          118  DEFINE('SETRS(X,Y)')  :(SETRS.END)
          119 SETRS ADDXRY(X,"MEMBER",Y)
