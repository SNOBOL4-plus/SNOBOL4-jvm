              *
          97   DEXP('SPLIT(SNP.LD) = SPLIT1(CDR(SNP),LD,CAR(SNP) ~'
              +        'NIL,NIL)')
              *
          98   DEFINE('SPLIT1(SNP,LD,NP,LNP)')   :(SPLIT1.END)
          99  SPLIT1   SPLIT1 =
              +     NULL(SNP) LREVERSE( LREVERSE(NP) ~ LNP)     :S(RETURN)
          100       SPLIT1 = MEMQ(CAR(SNP),LD)
