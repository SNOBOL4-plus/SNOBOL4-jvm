              +             LREVERSE(NP) ~ LNP)       :S(RETURN)
          101       SPLIT1 =
              +        SPLIT1( CDR(SNP), LD, CAR(SNP) ~ NP, LNP)
              +             :(RETURN)
          102 SPLIT1.END
              *
              * Some responses returned from semantic routines
