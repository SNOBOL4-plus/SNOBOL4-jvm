          103  UNDERSTAND = "I UNDERSTAND."
          104  YES = "YES."
          105  SOMETIMES = "SOMETIMES."
          106  INSUFFICIENT = "INSUFFICIENT INFORMATION"
          107  SILENCE = ""
              *
          108  DEFINE('SETR(X,Y)')    :(SETR.END)
