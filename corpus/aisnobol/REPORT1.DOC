          310         MOVE(PLAYER(CHOSEN),MOVEOF(CHOSEN))       :F(MAKE1)
          311         PRINTBRD()                                :(RETURN)
          312 MAKE1
          313         PRINTBRD()                                :(FRETURN)
          314 MAKE_END
              *
