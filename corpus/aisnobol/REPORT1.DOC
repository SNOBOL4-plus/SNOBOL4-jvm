          287         DEFINE( 'PLAY1(LNODES)' )          :(PLAY1_END)
          288 PLAY1
          289         NULL(REST(LNODES))                        :F(PLAY1A)
          290         CHOOSE(REST(LNODES),TOP(LNODES),"not calculated")
