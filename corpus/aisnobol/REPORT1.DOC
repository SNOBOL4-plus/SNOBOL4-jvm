                  END S1
          **********************************
                  S2
                      IF PARSE_WORD(THIS_NODE,'ADJECTIVE ') GOTO S2
                     AFTER ADDR('ADJECTIVES',LAST_PARSED)
                      ENDIF
                      IF PARSE_WORD(THIS_NODE,'NOUN ') GOTO WIN
