          294         DEFINE( 'CHOOSE(LNODES,BEST,V)NV' )  :(CHOOSE_END)
          295 CHOOSE
          296         NULL(LNODES)                         :S(CHOOSE2)
          297         EQ(V,INFINITY)                       :S(CHOOSE2)
          298         NV = SEARCH(TOP(LNODES),DEPTH,V,BETA)
          299         LE(NV,V)                             :S(CHOOSE1)



       AI Programming in SNOBOL4       - 68 -                    August, 1982








          300         V = NV
          301         BEST = TOP(LNODES)
