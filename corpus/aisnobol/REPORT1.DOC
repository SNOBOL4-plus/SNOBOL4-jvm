          **********************************
           FUNCTION PARSE_WORD_1 () ()
                  THIS_NODE = CURRENT_WORD ;
                  REMAINING_WORDS BREAK(" ") SPAN(" ") = ;
                  REMAINING_WORDS (BREAK(" ") | null) $ CURRENT_WORD  :(RET
          URN) ;
           END PARSE_WORD_1
          
